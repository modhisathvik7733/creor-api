# Database (Supabase Postgres connection pooler URL)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require

# Cashfree
CASHFREE_CLIENT_ID=your-cashfree-client-id
CASHFREE_CLIENT_SECRET=your-cashfree-client-secret
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret
CASHFREE_ENV=sandbox

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LLM Gateway (provider API keys for proxying)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# App
PORT=3001
CORS_ORIGIN=https://creor.ai,http://localhost:3000
